# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# RabbitMQ
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# Grafana
GRAFANA_PASSWORD=admin

# --- Path B: SolarWinds & Papertrail Migration ---
# Keep these unset for 100% local OSS mode
SW_OTEL_ENDPOINT=
SW_API_TOKEN=
PAPERTRAIL_HOST=
PAPERTRAIL_PORT=
